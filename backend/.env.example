# Backend server port
PORT=3001

# MongoDB Connection String
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Strava API Configuration
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
# For local: http://localhost:3001/api/auth/strava/callback
# For production: https://your-backend.onrender.com/api/auth/strava/callback
STRAVA_REDIRECT_URI=http://localhost:3001/api/auth/strava/callback

# JWT Secret for Auth
JWT_SECRET=your_random_secret_string

# Frontend URL (for CORS)
# For local: http://localhost:5173
# For production: https://your-frontend.netlify.app
VITE_APP_URL=http://localhost:5173
NODE_ENV=development
